# ==========================================================================
# Root-level environment variables (shared across the monorepo).
# App-specific variables (database, JWT, provider keys...) will be added
# to apps/api/.env.example and apps/web/.env.example in later milestones,
# when those apps are actually created.
# ==========================================================================

# development | test | production
NODE_ENV=development

# error | warn | info | debug
LOG_LEVEL=info
