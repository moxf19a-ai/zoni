# ==========================================================================
# apps/api environment variables.
# Copy this file to `.env` inside apps/api/ and fill in real values.
# Database, JWT, and provider secrets will be added here starting Milestone 3
# and Milestone 5, when those systems are actually implemented.
# ==========================================================================

NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:devpassword@localhost:5432/saas_platform_dev?schema=public"

# JWT — generate a real secret with: openssl rand -hex 32
JWT_ACCESS_SECRET="replace-with-a-random-secret-at-least-32-characters-long"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

# Security (Milestone 6)
# Comma-separated list of origins allowed to call this API from a browser.
CORS_ALLOWED_ORIGINS="http://localhost:5173"
# General rate limit: applies to every request except /health and /health/database.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
# Stricter limit for /api/v1/auth/* only — brute-force login/registration protection.
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# Channels / Plugin System (Milestone 8)
# Publicly reachable base URL of THIS API — used to build the OAuth
# redirect_uri and must exactly match what's registered in the Meta App
# dashboard. In production this is your real domain (e.g. https://api.example.com).
API_PUBLIC_BASE_URL="http://localhost:4000"
# Signs the short-lived OAuth "state" parameter — generate with: openssl rand -hex 32
OAUTH_STATE_SECRET="replace-with-a-random-secret-at-least-32-characters-long"
# AES-256 key for encrypting stored channel access tokens — generate with: openssl rand -hex 32
CHANNEL_TOKEN_ENCRYPTION_KEY="replace-with-a-64-character-hex-string-32-bytes"
# From your Meta App dashboard (App ID / App Secret) — required for Instagram OAuth.
INSTAGRAM_APP_ID="replace-with-your-meta-app-id"
INSTAGRAM_APP_SECRET="replace-with-your-meta-app-secret"
# Any string you choose — must match exactly what you enter in the Meta
# webhook subscription dashboard.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN="replace-with-a-verify-token-you-choose"

# AI providers (Milestone 10) — leave blank to disable a given provider
OPENAI_API_KEY=""
CLAUDE_API_KEY=""
GEMINI_API_KEY=""
